# Copy this file to .env and fill in your own local keys.
# Never commit real API keys.

# Optional: choose the LLM backend explicitly.
# Supported values: nvidia, anthropic, openai, google, ollama
LLM_PROVIDER=anthropic

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# NVIDIA NIM
NVAPI_KEY=your_nvidia_api_key_here
# Optional comma-separated fallback keys. The first working key is used, and
# later keys are tried if NVIDIA returns a temporary 429/503-style failure.
# NVAPI_KEYS=your_first_nvidia_key,your_second_nvidia_key
# NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o

# Google Gemini / Gemini Enterprise Agent Platform
# For local API-key testing, set GOOGLE_API_KEY and choose the google provider.
# LLM_PROVIDER=google
# GOOGLE_API_KEY=your_google_api_key_here
# GOOGLE_MODEL=gemini-2.5-flash
#
# For Google Cloud ADC, authenticate with:
#   gcloud auth application-default login
# Then configure project/location:
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-google-cloud-project
# GOOGLE_CLOUD_LOCATION=global

# Local Ollama (OpenAI-compatible API)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.1
