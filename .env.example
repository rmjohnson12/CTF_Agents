# Copy this file to .env and fill in your own local keys.
# Never commit real API keys.

# Optional: choose the LLM backend explicitly.
# Supported values: nvidia, anthropic, openai, google, ollama
LLM_PROVIDER=anthropic
# Per-provider request timeout. On quota, service, authorization, or timeout
# failures, the reasoner continues with the next configured provider.
LLM_TIMEOUT_SECONDS=20

# Anthropic Claude
ANTHROPIC_API_KEY=your_anthropic_api_key_here
ANTHROPIC_MODEL=claude-sonnet-4-5-20250929

# NVIDIA NIM
NVAPI_KEY=your_nvidia_api_key_here
# Optional comma-separated fallback keys. The first working key is used, and
# later keys are tried if NVIDIA returns a temporary 429/503-style failure.
# NVAPI_KEYS=your_first_nvidia_key,your_second_nvidia_key
# NVIDIA_MODEL=meta/llama-3.3-70b-instruct

# OpenAI
OPENAI_API_KEY=your_openai_api_key_here
# OPENAI_MODEL=gpt-4o

# Google Gemini / Gemini Enterprise Agent Platform
# For local API-key testing, set GOOGLE_API_KEY and choose the google provider.
# LLM_PROVIDER=google
# GOOGLE_API_KEY=your_google_api_key_here
# GEMINI_API_KEY=your_google_key_alias_if_preferred
# GOOGLE_MODEL=gemini-2.5-flash
#
# For Google Cloud ADC, authenticate with:
#   gcloud auth application-default login
# Then configure project/location:
# GOOGLE_GENAI_USE_VERTEXAI=true
# GOOGLE_CLOUD_PROJECT=your-google-cloud-project
# GOOGLE_CLOUD_LOCATION=global

# Local Ollama (OpenAI-compatible API)
# LLM_PROVIDER=ollama
# OLLAMA_BASE_URL=http://localhost:11434/v1
# OLLAMA_MODEL=llama3.1

# Generated-solver execution backend.
#   docker  -> run model-generated scripts in a locked-down throwaway container
#              (no network, read-only fs, ro artifact mounts, mem/cpu/pid limits,
#              strict timeout). Recommended. Requires a working Docker daemon.
#   unset   -> host execution, disabled unless the flag below is also set.
# CTF_AGENTS_SANDBOX=docker
# CTF_AGENTS_SANDBOX_IMAGE=python:3.11-slim-bookworm
# CTF_AGENTS_SANDBOX_MEMORY=256m
# CTF_AGENTS_SANDBOX_CPUS=1.0
# CTF_AGENTS_SANDBOX_PIDS=128
# If the default temp dir is not shared with Docker Desktop's VM, point this at
# a shared path (e.g. under the repo or /tmp).
# CTF_AGENTS_SANDBOX_TMPDIR=/tmp
# Sandbox network egress is fail-closed and currently unsupported. Network stays
# off even when an agent requests it until an enforcing sidecar is implemented.

# Optional dangerous runtime switches. Leave disabled unless the current
# challenge run is trusted and authorized. Prefer CTF_AGENTS_SANDBOX=docker over
# host execution: this flag runs arbitrary model-generated code on your machine.
# CTF_AGENTS_ALLOW_HOST_PYTHON_EXECUTION=1
# CTF_AGENTS_ALLOWED_NETWORKS=target.example,127.0.0.1

# Routing/planning determinism. 0 = most reproducible routing (default).
# CTF_AGENTS_SANDBOX and this are independent knobs.
# LLM_TEMPERATURE=0.0

# Optional live progress reporting. Leave URL unset to disable reporting.
# CTF_AGENTS_REPORTING_URL=https://reports.example.com
# CTF_AGENTS_REPORTING_WRITE_TOKEN=replace-with-a-long-random-token
# CTF_AGENTS_REPORTING_TIMEOUT=2
# Server-side settings:
# CTF_AGENTS_REPORTING_HOST=127.0.0.1
# CTF_AGENTS_REPORTING_PORT=8787
# CTF_AGENTS_REPORTING_DB=logs/reporting.db
# CTF_AGENTS_REPORTING_READ_TOKEN=replace-with-a-different-token
# CTF_AGENTS_REPORTING_ALLOWED_ORIGINS=https://ctf-agents.lovable.app
# CTF_AGENTS_REPORTING_PUBLIC_READ=0
# CTF_AGENTS_REPORT_FINAL_FLAG=0
# CTF_AGENTS_REPORTING_STORE_FLAGS=0
